# Weather API Configuration
# Get a free API key from https://openweathermap.org/api
WEATHER_API_KEY=75b5fbcb89d5a1b0e9b6a165915f3316

# ArcGIS Configuration (if using ArcGIS integration)
ARCGIS_API_KEY=your_arcgis_api_key_here

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (default is SQLite, can switch to PostgreSQL)
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/heatmap_db

# Email Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Celery/Scheduling (optional)
CELERY_BROKER_URL=redis://localhost:6379/0

# GIS/Spatial Database (optional)
USE_SPATIAL_DATABASE=False
GEOS_LIBRARY_PATH=/usr/lib/libgeos_c.so.1
